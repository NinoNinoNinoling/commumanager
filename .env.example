# ============================================================================
# 마녀봇 관리자 웹 환경 변수 설정
# ============================================================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요: cp .env.example .env

# Flask 환경 설정
# development: 개발 환경 (디버그 모드)
# production: 프로덕션 환경 (디버그 모드 비활성화)
FLASK_ENV=development

# Flask 시크릿 키 (세션 암호화에 사용)
# 프로덕션에서는 반드시 안전한 랜덤 문자열로 변경하세요
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ============================================================================
# Mastodon OAuth 설정
# ============================================================================
# Mastodon 인스턴스 URL (예: https://example.social)
MASTODON_INSTANCE_URL=https://your-instance.social

# Mastodon 애플리케이션 클라이언트 ID
# 발급 방법: Mastodon 인스턴스 > 설정 > 개발 > 새 애플리케이션
# 리다이렉트 URI: http://localhost:5000/auth/callback (개발)
#               https://your-domain.com/auth/callback (프로덕션)
# 필요한 권한: read:accounts
MASTODON_CLIENT_ID=your-client-id-here

# Mastodon 애플리케이션 클라이언트 시크릿
MASTODON_CLIENT_SECRET=your-client-secret-here

# ============================================================================
# 데이터베이스 설정
# ============================================================================
# SQLite 데이터베이스 파일 경로
# 상대 경로 또는 절대 경로 가능
# 기본값: economy.db (현재 디렉토리)
DATABASE_PATH=economy.db

# ============================================================================
# 서버 설정 (선택사항 - app.py에서 기본값 사용)
# ============================================================================
# HOST=0.0.0.0
# PORT=5000

# ============================================================================
# 추가 구성 요소 (봇, Redis, Celery 등)
# ============================================================================
# 아래 설정들은 봇 및 백그라운드 작업에 필요합니다
# 관리자 웹만 사용하는 경우 설정 불필요

# Bot configuration
# BOT_ACCESS_TOKEN=your-bot-access-token
# ADMIN_BOT_ACCESS_TOKEN=your-admin-bot-access-token

# PostgreSQL configuration (Mastodon 서버 DB 연동)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=mastodon
# POSTGRES_USER=mastodon
# POSTGRES_PASSWORD=your-postgres-password

# Redis configuration
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# Celery configuration
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
