# ============================================================
# Flask 기본 설정
# ============================================================
FLASK_ENV=production
SECRET_KEY=change_this_to_random_string
ADMIN_PASSWORD=admin123
DATABASE_PATH=/app/economy.db

# ============================================================
# 마스토돈 서버 정보
# ============================================================
# 외부에서 접근하는 마스토돈 인스턴스 URL
MASTODON_INSTANCE_URL=https://mastodon.social

# (선택) 컨테이너 내부에서 접근하는 마스토돈 인스턴스 URL
# Docker Compose 사용 시 서비스 이름으로 접근 가능
# 예: INTERNAL_MASTODON_INSTANCE_URL=http://mastodon-web:3000
# 설정하지 않으면 MASTODON_INSTANCE_URL을 사용합니다
INTERNAL_MASTODON_INSTANCE_URL=

# ============================================================
# 1. 총괄계정 (Admin Account)
# - OAuth 로그인용 (관리자 웹)
# - 공지 발행용
# ============================================================
# OAuth 앱 정보 (마스토돈 개발 탭에서 생성)
ADMIN_CLIENT_ID=
ADMIN_CLIENT_SECRET=
ADMIN_ACCESS_TOKEN=

# OAuth 리다이렉트 URI
MASTODON_REDIRECT_URI=https://your-domain.com/oauth/callback

# 하위 호환성 (기존 코드용)
MASTODON_CLIENT_ID=${ADMIN_CLIENT_ID}
MASTODON_CLIENT_SECRET=${ADMIN_CLIENT_SECRET}

# ============================================================
# 2. 시스템계정 (@봇)
# - 유저 친화적 봇
# - 재화 지급, 출석 체크, 명령어 처리
# ============================================================
SYSTEM_CLIENT_ID=
SYSTEM_CLIENT_SECRET=
SYSTEM_ACCESS_TOKEN=

# 하위 호환성 (기존 코드용)
BOT_ACCESS_TOKEN=${SYSTEM_ACCESS_TOKEN}

# ============================================================
# 3. 스토리계정
# - 스토리 콘텐츠 전용
# - 예약 발송
# ============================================================
STORY_CLIENT_ID=
STORY_CLIENT_SECRET=
STORY_ACCESS_TOKEN=

# ============================================================
# 4. 감독봇
# - 활동량 체크 및 경고 발송
# - 소셜 분석 (4가지 위험 유형)
# - 운영진 알림
# ============================================================
SUPERVISOR_CLIENT_ID=
SUPERVISOR_CLIENT_SECRET=
SUPERVISOR_ACCESS_TOKEN=

# ============================================================
# 웹훅 설정
# ============================================================
# 마스토돈 웹훅 서명 검증용 시크릿
# (마스토돈 관리자 페이지 > 웹훅 설정에서 동일한 값 입력)
MASTODON_WEBHOOK_SECRET=

# ============================================================
# 마스토돈 앱 생성 방법
# ============================================================
# 1. 마스토돈 로그인 → 설정 → 개발
# 2. "새 애플리케이션" 클릭
# 3. 애플리케이션 이름 입력
#    - 예: "총괄계정 API", "시스템봇 API" 등
# 4. 권한 설정:
#    - read (읽기)
#    - write (쓰기)
#    - follow (팔로우)
# 5. 생성 후 확인:
#    - Client ID (클라이언트 키)
#    - Client Secret (클라이언트 비밀키)
#    - Your access token (접근 토큰)
# 6. 위 3개 값을 각 계정의 환경 변수에 입력
#
# 주의사항:
# - 각 계정마다 별도의 앱을 생성해야 합니다
# - Access Token은 절대 공유하지 마세요
# - .env 파일은 .gitignore에 포함되어 있습니다
