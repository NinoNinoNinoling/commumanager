# 환경 변수 예시 (.env 파일로 복사하여 사용)

# Flask 앱 시크릿 키 (프로덕션에서는 강력한 랜덤 값으로 변경 필수!)
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# 관리자 비밀번호 (프로덕션에서는 반드시 변경!)
# 기본값: admin123
ADMIN_PASSWORD=your-admin-password-here

# Mastodon OAuth 설정
# Mastodon 인스턴스 URL (예: https://mastodon.social)
MASTODON_INSTANCE_URL=https://mastodon.social

# Mastodon 앱 클라이언트 ID (앱 등록 후 받은 값)
MASTODON_CLIENT_ID=your-client-id-here

# Mastodon 앱 클라이언트 시크릿 (앱 등록 후 받은 값)
MASTODON_CLIENT_SECRET=your-client-secret-here

# OAuth 콜백 URL (기본값: http://localhost:5000/oauth/callback)
MASTODON_REDIRECT_URI=http://localhost:5000/oauth/callback

# 관리자 계정 목록 (쉼표로 구분, 예: admin@mastodon.social,user@example.com)
MASTODON_ADMIN_ACCOUNTS=admin@mastodon.social
