# [필수] Flask 설정
FLASK_ENV=production
SECRET_KEY=change_this_to_random_string
ADMIN_PASSWORD=admin123
# DATABASE_PATH는 docker-compose에서 고정했으므로 생략 가능하지만 명시
DATABASE_PATH=/app/economy.db

# [필수] 마스토돈 OAuth
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=
MASTODON_REDIRECT_URI=https://your-domain.com/oauth/callback

# [필수] 봇 토큰
BOT_ACCESS_TOKEN=
STORY_ACCESS_TOKEN=
SUPERVISOR_ACCESS_TOKEN=

# [필수] 웹훅 시크릿
MASTODON_WEBHOOK_SECRET=
