# ----------------------------------------------------
# 🔐 COMMUMANAGER SECURITY & LOCAL ADMIN
# ----------------------------------------------------
# Flask 앱 시크릿 키 (웹 세션 암호화용)
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
# 프로덕션에서는 강력한 랜덤 값으로 변경 필수!
SECRET_KEY=your-secret-key-here-change-in-production

# 관리자 비밀번호 (기본 로그인 방식용)
# 프로덕션에서는 반드시 변경!
ADMIN_PASSWORD=your-admin-password-here

# ----------------------------------------------------
# 🐘 MASTODON & BOT API CONNECTION
# ----------------------------------------------------
# Mastodon 인스턴스 URL
# 예: https://mastodon.social 또는 https://your-instance.example.com
MASTODON_INSTANCE_URL=https://mastodon.social

# 봇 액세스 토큰 (봇 계정으로 API 호출 시 사용)
# Mastodon 개발 콘솔 → 새 애플리케이션 → 액세스 토큰 복사
BOT_ACCESS_TOKEN=your-bot-access-token-here

# Mastodon OAuth 앱 클라이언트 ID
# Mastodon 개발 콘솔 → 애플리케이션 등록 후 받은 값
MASTODON_CLIENT_ID=your-client-id-here

# Mastodon OAuth 앱 클라이언트 시크릿
# Mastodon 개발 콘솔 → 애플리케이션 등록 후 받은 값
MASTODON_CLIENT_SECRET=your-client-secret-here

# OAuth 콜백 URL (관리자 웹 주소)
# 로컬 개발: http://localhost:5000/oauth/callback
# 프로덕션: https://your-admin-domain.com/oauth/callback
# 주의: Mastodon 개발 콘솔의 리디렉션 URI와 정확히 일치해야 함!
MASTODON_REDIRECT_URI=http://localhost:5000/oauth/callback

# 관리자 계정 목록 (OAuth 권한 확인용)
# ⚠️  더 이상 사용되지 않습니다!
# 이제 DB의 oauth_admins 테이블로 관리됩니다.
# 관리자 추가: python3 add_oauth_admin.py <mastodon_acct> [display_name]
# 관리자 목록: python3 list_oauth_admins.py
# MASTODON_ADMIN_ACCOUNTS=admin  # 사용 중단됨

# ----------------------------------------------------
# 🔗 MASTODON WEBHOOK SECRET
# ----------------------------------------------------
# 마스토돈 웹훅 서명 검증용 비밀키
# 마스토돈 관리자 페이지에서 웹훅 등록 시 설정한 비밀키와 동일해야 함
# 생성 방법: python -c "import secrets; print(secrets.token_hex(32))"
MASTODON_WEBHOOK_SECRET=your-webhook-secret-here
