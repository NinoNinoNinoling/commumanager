# Flask configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# Mastodon configuration
MASTODON_INSTANCE_URL=https://your-instance.example.com
MASTODON_CLIENT_ID=your-client-id
MASTODON_CLIENT_SECRET=your-client-secret

# Database configuration
DATABASE_PATH=economy.db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mastodon
POSTGRES_USER=mastodon
POSTGRES_PASSWORD=your-postgres-password

# Bot configuration
BOT_ACCESS_TOKEN=your-bot-access-token
ADMIN_BOT_ACCESS_TOKEN=your-admin-bot-access-token
